# ─── Дружок — environment ───────────────────────────────────────────────
# Copy to .env for local dev (or set these in Railway → Variables).
# With NO BOT_TOKEN the server runs in DEV MODE: auth is stubbed to a single
# local user, payments + reminders are inert. Perfect for local playtesting.

# From @BotFather (/newbot). Required in production.
BOT_TOKEN=

# Public HTTPS origin of the deployed app (Railway gives you one),
# e.g. https://druzhok-production.up.railway.app
# Used for the Telegram webhook + the "Открыть Дружка" web_app button.
APP_URL=

# The bot's @username without the @ (for invite deep links).
BOT_USERNAME=druzhok_pet_bot

# Secret path segment for the Telegram webhook (any random string).
WEBHOOK_SECRET=change-me-to-something-random

# Signs session JWTs (any long random string).
JWT_SECRET=change-me-to-a-long-random-string

# SQLite location. On Railway, point this at the mounted volume, e.g. /data
DATA_DIR=./data

# Monetization kill-switch. Leave UNSET (or !=1) to keep «Дружок Плюс»
# DORMANT — everything unlocked, paywall screens show "всё бесплатно".
# Set to 1 to enforce the subscription and activate Telegram Stars.
PLUS_ENFORCED=

# Admin key for the refund endpoint (POST /api/payments/refund).
ADMIN_KEY=

# Port (Railway sets this automatically).
PORT=3000
